# Server
PORT=8080
ENV=development

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_DAYS=7

# Postgres
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus

# Redis
REDIS_URL=redis://localhost:6379

# Upstream APIs
GITHUB_TOKEN=ghp_your_token_here

# IBKR Client Portal Gateway (must be running locally before starting nexus)
# Download from: https://www.interactivebrokers.com/en/trading/ib-api.php
# If IBKR_USERNAME and IBKR_PASSWORD are set, nexus will attempt auto-authentication.
# Leave them blank to authenticate manually via browser at https://localhost:5000
IBKR_GATEWAY_URL=https://localhost:5000
IBKR_USERNAME=
IBKR_PASSWORD=

# Rate limits
RATE_LIMIT_AUTHED=100
RATE_LIMIT_APIKEY=500
RATE_LIMIT_WINDOW_SECONDS=60

# OpenTelemetry (Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
